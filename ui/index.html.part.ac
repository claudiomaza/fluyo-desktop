        const { h, Component } = preact;
        const db = new Dexie('fastAppDB');
        db.version(1).stores({ items: '++id, title, timestamp' });

        
function blindRender(vnode, container) {
    const activeEl = document.activeElement;
    let focusId = activeEl?.dataset?.focus;
    let selStart = activeEl?.selectionStart;
    let selEnd = activeEl?.selectionEnd;
    
    const mounts = [];
    container.innerHTML = "";

    function build(node) {
        if (node == null || typeof node === "boolean") return null;
        if (typeof node === "string" || typeof node === "number") return document.createTextNode(node);
        
        if (typeof node.type === "function") {
            const inst = new node.type(node.props);
            const dom = build(inst.render());
            if (inst.componentDidMount && !inst.__mounted) mounts.push(inst);
            return dom;
        }

        const el = document.createElement(node.type);
        if (node.props) {
            for (const [k, v] of Object.entries(node.props)) {
                if (k === "class") el.className = v;
                else if (k.startsWith("on")) el.addEventListener(k.toLowerCase().substring(2), v);
                else el.setAttribute(k, v);
            }
            const children = [].concat(node.props.children || []);
            children.forEach(c => {
                const d = build(c);
                if (d) el.appendChild(d);
            });
        }
        return el;
    }

    const root = build(vnode);
    if (root) container.appendChild(root);

    // Ciclo de vida post-DOM
    mounts.forEach(i => {
        i.componentDidMount();
        i.__mounted = true;
    });

    // Restauración de Foco y Cursor
    if (focusId) {
        const target = container.querySelector(`[data-focus="${focusId}"]`);
        if (target) {
            target.focus();
            if (selStart !== undefined) target.setSelectionRange(selStart, selEnd);
        }
    }
}


        class App extends Component {
            constructor() {
                super();
                this.state = { items: [], loading: true, q: '' };
            }
            async componentDidMount() {
                const items = await db.items.toArray();
                this.setState({ items, loading: false });
            }
            async add() {
                const title = 'Item ' + (this.state.items.length + 1);
                await db.items.add({ title, timestamp: Date.now() });
                const items = await db.items.toArray();
                this.setState({ items });
            }
            render() {
                const filtered = this.state.items.filter(i => i.title.toLowerCase().includes(this.state.q.toLowerCase()));
                return h('div', { class: 'app-wrap' }, [
                    h('header', { class: 'app-header' }, h('h1', { class: 'app-title' }, '⚡ Fast-App Compact Blindada')),
                    h('main', { class: 'app-main' }, [
                        h('div', { class: 'search-row' }, [
                            h('input', {
                                type: 'text', placeholder: '🔍 Buscar...', class: 'search-input',
                                "data-focus": "main-search", value: this.state.q,
                                onInput: (e) => {
                                    this.setState({ q: e.target.value });
                                    blindRender(h(App), document.getElementById('app'));
                                }
                            }),
                            h('button', { onClick: () => this.add(), class: 'btn-add' }, '+ Añadir')
                        ]),
                        this.state.loading ? h('p', { class: 'msg-empty' }, 'Cargando...') : h('div', { class: 'item-list' },
                            filtered.map(i => h('div', { key: i.id, class: 'item-card' }, h('div', { class: 'item-title' }, i.title)))
                        )
                    ])
                ]);
            }
        }

        blindRender(h(App), document.getElementById('app'));
    } catch(e) {
        document.body.innerHTML = '<pre style="color:red; padding:20px;">' + e.stack + '</pre>';
    }
    </script>
</body>
</html>