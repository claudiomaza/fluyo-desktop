<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
    <title>Fast-App Compact Blindada</title>
    <style>/* style.css - Fast-App Tier 2 Base Theme */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html, body {
    background: #0f172a;
    color: #f8fafc;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    font-size: 16px;
    min-height: 100vh;
    -webkit-text-size-adjust: 100%;
}

.app-wrap {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
}

.app-header {
    background: #1e293b;
    border-bottom: 1px solid #334155;
    padding: 16px 20px;
    position: sticky;
    top: 0;
    z-index: 10;
}

.app-title {
    font-size: clamp(18px, 5vw, 26px);
    font-weight: 700;
    color: #60a5fa;
}

.app-main {
    flex: 1;
    padding: 16px;
    max-width: 680px;
    width: 100%;
    margin: 0 auto;
}

.search-row {
    display: flex;
    gap: 10px;
    margin-bottom: 16px;
    flex-wrap: wrap;
}

.search-input {
    flex: 1;
    min-width: 0;
    background: #1e293b;
    border: 1px solid #334155;
    color: #f8fafc;
    padding: 12px 14px;
    border-radius: 10px;
    font-size: 16px;
    -webkit-appearance: none;
    appearance: none;
}

.search-input:focus {
    outline: 2px solid #3b82f6;
    outline-offset: 1px;
}

.search-input::placeholder { color: #64748b; }

.btn-add {
    background: #2563eb;
    color: #fff;
    border: none;
    padding: 12px 20px;
    border-radius: 10px;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    white-space: nowrap;
    -webkit-tap-highlight-color: transparent;
    touch-action: manipulation;
}

.btn-add:active { opacity: 0.8; }

.msg-empty {
    color: #64748b;
    text-align: center;
    margin-top: 48px;
    font-size: 15px;
}

.item-list { display: flex; flex-direction: column; gap: 10px; }

.item-card {
    background: #1e293b;
    border: 1px solid #334155;
    border-radius: 10px;
    padding: 14px 16px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
}

.item-info { flex: 1; min-width: 0; }

.item-title {
    font-size: 15px;
    font-weight: 500;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}

.item-date {
    font-size: 12px;
    color: #64748b;
    margin-top: 4px;
}

.btn-delete {
    background: #450a0a;
    color: #fca5a5;
    border: none;
    padding: 8px 12px;
    border-radius: 8px;
    font-size: 16px;
    cursor: pointer;
    flex-shrink: 0;
    -webkit-tap-highlight-color: transparent;
    touch-action: manipulation;
}

.btn-delete:active { opacity: 0.8; }

@media (max-width: 480px) {
    .app-main { padding: 12px; }
    .search-row { flex-direction: column; }
    .btn-add { width: 100%; text-align: center; }
}
</style>
</head>
<body>
    <div id="app"></div>
    <script>
